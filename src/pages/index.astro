---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SobreMi from "../components/SobreMi.astro";
import Projects from "../components/Projects.astro";
import Process from "../components/Process.astro";
import Services from "../components/Services.astro";
import Contacto from "../components/Contacto.astro";
import FaqHome from "../components/FaqHome.astro";
import { org, website, localBusiness } from "../seo/structured";

const title =
  "Desarrollador web en Zaragoza | Rescate web, apps y SEO técnico | ByteZagal";
const description =
  "Desarrollador web en Zaragoza. Rescate web, desarrollo a medida, apps, automatización y SEO técnico para negocios que necesitan una web rápida, clara y orientada a resultados.";

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://bytezagal.es/#webpage-home",
  url: "https://bytezagal.es/",
  name: title,
  description,
  inLanguage: "es-ES",
  isPartOf: { "@id": "https://bytezagal.es/#website" },
  about: { "@id": "https://bytezagal.es/#professional-service" },
  primaryImageOfPage: "https://bytezagal.es/bytezagal-og.home.webp"
};

const faqHome = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Trabajas en Zaragoza o también en remoto?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Trabajo con foco en Zaragoza y también en remoto para clientes de toda España."
      }
    },
    {
      "@type": "Question",
      name: "¿Qué tipo de proyectos haces?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Rescate de webs, desarrollo web a medida, desarrollo de apps, SEO técnico, automatización y mejoras de rendimiento y accesibilidad."
      }
    },
    {
      "@type": "Question",
      name: "¿Puedes arreglar una web ya existente?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí. Puedo auditar, estabilizar y mejorar webs lentas, rotas o mal planteadas sin rehacerlo todo desde cero."
      }
    },
    {
      "@type": "Question",
      name: "¿Cómo empezamos?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Cuéntame tu caso y te diré la vía más sensata: parche, refactor controlado o reconstrucción parcial."
      }
    }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  image="/bytezagal-og.home.webp"
  jsonLd={[org, website, localBusiness, pageSchema, faqHome]}
  bodyClass="text-slate-800 antialiased"
>
  <Hero />
  <SobreMi />
  <Projects />
  <Process />
  <Services />
  <Contacto />
  <FaqHome />
</BaseLayout>
