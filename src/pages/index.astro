---
import "../styles/globals.css";
import Seo from "../components/Seo.astro";
import Hero from "../components/Hero.astro";
import SobreMi from "../components/SobreMi.astro";
import Projects from "../components/Projects.astro";
import Process from "../components/Process.astro";
import Services from "../components/Services.astro";
import MiniLab from "../components/MiniLab.astro";
import Contacto from "../components/Contacto.astro";
import Footer from "../components/Footer.astro";
import FaqHome from "../components/FaqHome.astro";

import { org, website, localBusiness } from "../seo/structured";

const title = "ByteZagal | Rescate web, desarrollo y SEO técnico en Zaragoza";
const description =
  "Rescate web, desarrollo y SEO técnico en Zaragoza y remoto en España. Webs rápidas, accesibles y pensadas para negocio.";

const faqHome = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Trabajas en Zaragoza o también en remoto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Trabajo con foco en Zaragoza y también en remoto para clientes de toda España."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué tipo de proyectos haces?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rescate de webs, desarrollo web a medida, SEO técnico, automatización y mejoras de rendimiento y accesibilidad."
      }
    },
    {
      "@type": "Question",
      "name": "¿Puedes arreglar una web ya existente?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Puedo auditar, estabilizar y mejorar webs lentas, rotas o mal planteadas sin rehacerlo todo desde cero."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo empezamos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cuéntame tu caso y te diré la vía más sensata: parche, refactor controlado o reconstrucción parcial."
      }
    }
  ]
};
---
<!doctype html>
<html lang="es" class="h-full">
  <head>
    <Seo
      title={title}
      description={description}
      canonicalPath="/"
      jsonLd={[org, website, localBusiness, faqHome]}
    />
  </head>
  <body class="bg-orbital text-slate-800 antialiased">
    <a href="#contenido" class="skip-link">Saltar al contenido</a>

    <Hero />

    <main id="contenido">
      <SobreMi />
      <Projects />
      <Process />
      <Services />
      <MiniLab />
      <Contacto />
      <FaqHome />
      <Footer />
    </main>
  </body>
</html>
