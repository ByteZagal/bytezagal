---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectGallery from "../../components/ProjectGallery.astro";

const title = "Turbolin | App para torneos, ranking y fidelización en hostelería | ByteZagal";
const description =
  "Caso de app para organizar torneos, recompensas y ranking en locales con futbolín, con una experiencia clara pensada para fidelizar y generar recurrencia.";

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://bytezagal.es/proyectos/turbolin#webpage",
  url: "https://bytezagal.es/proyectos/turbolin",
  name: title,
  description,
  isPartOf: {
    "@id": "https://bytezagal.es/#website"
  },
  about: {
    "@type": "SoftwareApplication",
    name: "Turbolin",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://bytezagal.es/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Proyectos",
      item: "https://bytezagal.es/proyectos"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Turbolin",
      item: "https://bytezagal.es/proyectos/turbolin"
    }
  ]
};

const slides = [
  {
    src: "/turboHome.webp",
    alt: "Pantalla principal de Turbolin con acceso a la experiencia de juego y torneos",
    label: "Inicio",
    caption: "Entrada clara para activar la experiencia y entender rápido cómo funciona."
  },
  {
    src: "/turboTorneos.webp",
    alt: "Pantalla de torneos de Turbolin",
    label: "Torneos",
    caption: "Gestión de torneos pensada para generar movimiento, participación y recurrencia."
  },
  {
    src: "/turboPremios.webp",
    alt: "Pantalla de recompensas y premios de Turbolin",
    label: "Premios",
    caption: "Sistema de premios para reforzar fidelización y motivar la vuelta al local."
  },
  {
    src: "/turboCrear.webp",
    alt: "Pantalla de creación y configuración dentro de Turbolin",
    label: "Configuración",
    caption: "Configuración sencilla para lanzar dinámicas sin procesos torpes."
  },
  {
    src: "/turboBar.webp",
    alt: "Vista de Turbolin orientada al local y su operativa",
    label: "Local",
    caption: "Una capa de producto pensada para conectar experiencia de juego y negocio real."
  }
] as const;

const chips = [
  "PWA",
  "Torneos",
  "Ranking",
  "Recompensas",
  "Hostelería",
  "Fidelización"
];

const valueCards = [
  {
    title: "Qué es",
    text: "Una app para organizar torneos, clasificaciones y recompensas alrededor del futbolín en un local."
  },
  {
    title: "Cómo ayuda",
    text: "Convierte una actividad social en una experiencia mejor estructurada, más activa y con más retorno."
  },
  {
    title: "Qué transmite",
    text: "Capacidad para diseñar producto con lógica de negocio, comunidad y uso recurrente."
  }
];

const fitList = [
  "Locales que quieren activar comunidad y crear una razón real para volver.",
  "Espacios con futbolín u ocio presencial que buscan más movimiento y fidelización.",
  "Negocios que quieren unir experiencia física, ranking y recompensas en una sola propuesta."
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/proyectos/turbolin"
  jsonLd={[pageSchema, breadcrumbSchema]}
  bodyClass="text-slate-800"
>
  <section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex flex-wrap items-center gap-2">
        <li>
          <a
            href="/"
            class="inline-flex min-h-10 items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
          >
            Inicio
          </a>
        </li>
        <li>
          <a
            href="/proyectos"
            class="inline-flex min-h-10 items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
          >
            Proyectos
          </a>
        </li>
        <li>
          <span
            class="inline-flex min-h-10 items-center rounded-full border border-slate-900 bg-slate-900 px-4 py-2 text-sm font-semibold text-white"
            aria-current="page"
          >
            Turbolin
          </span>
        </li>
      </ol>
    </nav>

    <section class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
          Caso privado
        </p>

        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
          Turbolin
        </h1>

        <p class="mt-5 text-lg leading-8 text-slate-600">
          App para crear torneos, rankings y recompensas alrededor del futbolín,
          pensada para activar comunidad, fidelizar y dar más vida al local.
        </p>

        <ul
          class="mt-6 flex flex-wrap gap-2"
          aria-label="Tecnologías y enfoque de Turbolin"
        >
          {chips.map((item) => (
            <li class="chip">{item}</li>
          ))}
        </ul>

        <p class="mt-6 rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-sm leading-7 text-slate-600 shadow-[0_12px_30px_rgba(15,23,42,0.05)]">
          Proyecto en fase privada. Esta demo visual enseña el enfoque de producto,
          la experiencia de uso y el potencial de negocio sin exponer operativa sensible.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contratame" class="cta black">
            Quiero algo así
          </a>

          <a href="/proyectos" class="cta white">
            Volver al hub
          </a>
        </div>
      </div>

      <ProjectGallery
        slides={slides}
        mode="mobile"
        ariaLabel="Galería del proyecto Turbolin"
      />
    </section>

    <section class="mt-14">
      <div class="grid gap-6 md:grid-cols-3">
        {valueCards.map((card) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white/90 p-6 shadow-[0_18px_40px_rgba(15,23,42,0.05)]">
            <h2 class="text-xl font-bold tracking-tight text-slate-900">
              {card.title}
            </h2>
            <p class="mt-3 leading-7 text-slate-600">
              {card.text}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-14 grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      <article class="rounded-[2rem] border border-slate-200 bg-white/90 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">
          Enfoque del proyecto
        </h2>

        <div class="mt-5 space-y-4 text-base leading-8 text-slate-600">
          <p>
            Turbolin parte de una idea muy sencilla, pero potente: cuando una actividad
            presencial se estructura bien, deja de ser un rato suelto y se convierte en
            una dinámica que trae gente de vuelta.
          </p>

          <p>
            Torneos, clasificaciones y recompensas no están aquí como adorno. Están
            pensados para crear participación, generar conversación y reforzar el vínculo
            entre experiencia y consumo dentro del local.
          </p>

          <p>
            Es un buen ejemplo de producto con lógica de negocio: una capa digital que
            ordena el juego, da contexto a la comunidad y abre una vía clara para aumentar recurrencia.
          </p>
        </div>
      </article>

      <aside class="rounded-[2rem] border border-slate-200 bg-white/90 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">
          Dónde encaja bien una solución así
        </h2>

        <ul class="mt-5 space-y-3 text-slate-600">
          {fitList.map((item) => (
            <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 leading-7">
              {item}
            </li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="mt-14">
      <div class="rounded-[2rem] border border-slate-900 bg-slate-900 px-6 py-8 text-white shadow-[0_18px_50px_rgba(15,23,42,0.16)] md:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-300">
          Siguiente paso
        </p>

        <h2 class="mt-3 text-3xl font-extrabold tracking-tight">
          Si quieres activar comunidad y mover más tu local, hablemos
        </h2>

        <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
          Desde hostelería hasta espacios con experiencias presenciales: la meta es
          transformar una actividad puntual en una palanca de fidelización y recurrencia.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contratame" class="cta white">
            Cuéntame tu proyecto
          </a>
          <a href="/proyectos" class="cta ghost-light">
            Ver más casos
          </a>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
