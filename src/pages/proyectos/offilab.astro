---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectGallery from "../../components/ProjectGallery.astro";

const title = "OffiLab | App privada para gestión de equipos y operativa | ByteZagal";
const description =
  "Caso de app privada para coordinar oficina y operarios: tareas, fichajes, documentación, automatización y control más claro del día a día.";

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://bytezagal.es/proyectos/offilab#webpage",
  url: "https://bytezagal.es/proyectos/offilab",
  name: title,
  description,
  isPartOf: {
    "@id": "https://bytezagal.es/#website"
  },
  about: {
    "@type": "SoftwareApplication",
    name: "OffiLab",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://bytezagal.es/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Proyectos",
      item: "https://bytezagal.es/proyectos"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "OffiLab",
      item: "https://bytezagal.es/proyectos/offilab"
    }
  ]
};

const slides = [
  {
    src: "/offiDashBoard.webp",
    alt: "Dashboard principal de OffiLab para gestión de operativa",
    label: "Dashboard",
    caption: "Vista central para supervisar operativa, equipo y tareas sin perder tiempo."
  },
  {
    src: "/offiLogin1.webp",
    alt: "Pantalla de acceso móvil de OffiLab",
    label: "Acceso móvil",
    caption: "Entrada rápida para operarios y responsables desde una experiencia clara."
  },
  {
    src: "/offiLogin2.webp",
    alt: "Segunda pantalla de acceso de OffiLab",
    label: "Acceso 2",
    caption: "Flujo de acceso pulido para usar la app desde móvil en el día a día."
  },
  {
    src: "/offiTrabajadores.webp",
    alt: "Gestión de trabajadores en OffiLab",
    label: "Equipo",
    caption: "Control de personal, estado y organización del trabajo desde una sola vista."
  },
  {
    src: "/offiPendiente.webp",
    alt: "Pantalla de tareas pendientes de OffiLab",
    label: "Tareas",
    caption: "Seguimiento de pendientes y operativa sin depender de mensajes dispersos."
  }
] as const;

const chips = [
  "React",
  "Node.js",
  "TypeScript",
  "OCR",
  "PWA",
  "Operativa real"
];

const valueCards = [
  {
    title: "Qué es",
    text: "Una app privada para coordinar oficina y operarios con menos fricción, menos caos y más control."
  },
  {
    title: "Cómo ayuda",
    text: "Centraliza tareas, fichajes, documentación y seguimiento para que el trabajo fluya mejor."
  },
  {
    title: "Qué transmite",
    text: "Capacidad para convertir procesos cotidianos en una herramienta clara, útil y fácil de usar."
  }
];

const fitList = [
  "Empresas de servicios con personal en calle y coordinación desde oficina.",
  "Equipos que siguen gestionando demasiadas cosas por WhatsApp, papel o memoria.",
  "Negocios que quieren automatizar documentación y ahorrar tiempo operativo."
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/proyectos/offilab"
  jsonLd={[pageSchema, breadcrumbSchema]}
  bodyClass="text-slate-800"
>
  <section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex flex-wrap items-center gap-2">
        <li>
          <a
            href="/"
            class="inline-flex min-h-10 items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
          >
            Inicio
          </a>
        </li>
        <li>
          <a
            href="/proyectos"
            class="inline-flex min-h-10 items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
          >
            Proyectos
          </a>
        </li>
        <li>
          <span
            class="inline-flex min-h-10 items-center rounded-full border border-slate-900 bg-slate-900 px-4 py-2 text-sm font-semibold text-white"
            aria-current="page"
          >
            OffiLab
          </span>
        </li>
      </ol>
    </nav>

    <section class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
          Caso privado
        </p>

        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
          OffiLab
        </h1>

        <p class="mt-5 text-lg leading-8 text-slate-600">
          Doble PWA para coordinar oficina y operarios: tareas, fichajes, seguimiento
          y documentación en una experiencia más rápida, clara y fácil de mantener.
        </p>

        <ul
          class="mt-6 flex flex-wrap gap-2"
          aria-label="Tecnologías y enfoque de OffiLab"
        >
          {chips.map((item) => (
            <li class="chip">{item}</li>
          ))}
        </ul>

        <p class="mt-6 rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-sm leading-7 text-slate-600 shadow-[0_12px_30px_rgba(15,23,42,0.05)]">
          Proyecto en fase privada. Aquí se muestra una demo visual orientada a enseñar
          criterio de producto, operativa y experiencia de uso, sin exponer información sensible.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contratame" class="cta black">
            Quiero algo así
          </a>

          <a href="/proyectos" class="cta white">
            Volver al hub
          </a>
        </div>
      </div>

      <ProjectGallery
        slides={slides}
        mode="mixed"
        ariaLabel="Galería del proyecto OffiLab"
      />
    </section>

    <section class="mt-14">
      <div class="grid gap-6 md:grid-cols-3">
        {valueCards.map((card) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white/90 p-6 shadow-[0_18px_40px_rgba(15,23,42,0.05)]">
            <h2 class="text-xl font-bold tracking-tight text-slate-900">
              {card.title}
            </h2>
            <p class="mt-3 leading-7 text-slate-600">
              {card.text}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-14 grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      <article class="rounded-[2rem] border border-slate-200 bg-white/90 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">
          Enfoque del proyecto
        </h2>

        <div class="mt-5 space-y-4 text-base leading-8 text-slate-600">
          <p>
            OffiLab nace para resolver una fricción muy común: lo que pasa en oficina
            y lo que pasa fuera no siempre viajan bien juntos. Cuando tareas, fichajes,
            documentos y seguimiento van cada uno por su lado, la operativa se vuelve más lenta.
          </p>

          <p>
            La propuesta aquí es reunir esas piezas en una herramienta pensada para trabajar
            con menos pasos y menos ruido. Que el responsable tenga visibilidad y que el operario
            encuentre rápido lo que necesita desde el móvil.
          </p>

          <p>
            Además, la capa de automatización documental con OCR apunta justo a donde más duele:
            ahorrar tiempo en gestiones repetitivas y reducir trabajo manual que no aporta valor.
          </p>
        </div>
      </article>

      <aside class="rounded-[2rem] border border-slate-200 bg-white/90 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">
          Dónde encaja bien una solución así
        </h2>

        <ul class="mt-5 space-y-3 text-slate-600">
          {fitList.map((item) => (
            <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 leading-7">
              {item}
            </li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="mt-14">
      <div class="rounded-[2rem] border border-slate-900 bg-slate-900 px-6 py-8 text-white shadow-[0_18px_50px_rgba(15,23,42,0.16)] md:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-300">
          Siguiente paso
        </p>

        <h2 class="mt-3 text-3xl font-extrabold tracking-tight">
          Si quieres una operativa más clara entre oficina y campo, hablemos
        </h2>

        <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
          Desde equipos técnicos hasta negocios con mucha coordinación diaria: la meta
          es reducir pasos, ordenar procesos y convertir el caos en una herramienta útil.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contratame" class="cta white">
            Cuéntame tu proyecto
          </a>
          <a href="/proyectos" class="cta ghost-light">
            Ver más casos
          </a>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
