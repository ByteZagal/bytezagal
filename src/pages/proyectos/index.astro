---
import "../../styles/globals.css";
import Seo from "../../components/Seo.astro";
import Footer from "../../components/Footer.astro";

const title = "Proyectos web en Vitoria-Gasteiz — ByteZagal";
const description =
  "Showcase de proyectos: webs, PWAs y apps creadas en Vitoria-Gasteiz. Casos reales como ParROCKia, PisoNauta y TxoriON.";
---

<html lang="es">
  <head>
    <Seo title={title} description={description} canonicalPath="/proyectos" />
  </head>
  <body class="bg-orbital text-slate-800">
    <main class="mx-auto max-w-6xl px-4 py-16">
      <h1 class="text-4xl font-extrabold text-center">
        Proyectos realizados en Vitoria-Gasteiz
      </h1>
      <p class="mt-3 text-center text-slate-600 max-w-2xl mx-auto">
        Selección de proyectos que muestran mi trabajo real y en desarrollo:
        webs vivas, apps cívicas y experimentos creativos.
      </p>

      <!-- Carrusel -->
      <section class="relative mt-12 overflow-x-auto snap-x snap-mandatory flex gap-8 pb-6">
        {[
          {
            slug: "parrockia",
            title: "ParROCKia",
            desc:
              "Web de la taberna punk-rock de la Kutxi en Gasteiz. Optimizada para SEO local y lista para crecer.",
            img: "/parrockia.webp",
            tech: ["React", "Tailwind", "PHP (API)"],
            link: "https://tabernaparrockia.com",
            repo: null,
          },
          {
            slug: "pisonauta",
            title: "PisoNauta",
            desc:
              "PWA para mejorar la convivencia en pisos compartidos: tareas, lista de la compra, gastos y rutinas.",
            img: "/pisonauta-movil.webp",
            tech: ["React", "Supabase", "Vercel", "Tailwind"],
            link: null,
            repo: "https://github.com/ByteZagal/PisoNautaApp",
          },
          {
            slug: "txorion",
            title: "TxoriON",
            desc:
              "PWA cívica para Vitoria-Gasteiz: agenda de eventos, comercios y recursos municipales.",
            img: "/txorion-eventos.webp",
            tech: ["React", "Supabase", "Vercel", "Tailwind"],
            link: null,
            repo: null,
          },
          {
            slug: "twilight-reborn",
            title: "Twilight Reborn",
            desc:
              "Videojuego RPG multijugador 2.5D pixelado en fase de planteamiento.",
            img: "/twilight.webp",
            tech: ["Unity", "C#"],
            link: null,
            repo: null,
          },
        ].map((p) => (
          <article
            class="min-w-[90%] md:min-w-[70%] lg:min-w-[60%] snap-center bg-white rounded-2xl shadow-lg ring-1 ring-slate-200 p-6 flex flex-col transition hover:-translate-y-1 hover:shadow-2xl"
          >
            <div class="relative w-full aspect-[16/9] overflow-hidden rounded-xl">
              <img
                src={p.img}
                alt={p.title}
                class="absolute inset-0 w-full h-full object-cover transition duration-300 group-hover:scale-[1.05]"
                loading="lazy"
              />
            </div>

            <h2 class="mt-4 text-2xl font-bold">{p.title}</h2>
            <p class="mt-2 text-slate-600">{p.desc}</p>

            <ul class="mt-3 flex flex-wrap gap-2">
              {p.tech.map((t) => <li class="chip">{t}</li>)}
            </ul>

            <div class="mt-4 flex flex-wrap gap-3">
              {p.link && (
                <a href={p.link} target="_blank" rel="noopener noreferrer" class="cta black">
                  Ver página
                </a>
              )}
              {p.repo && (
                <a href={p.repo} target="_blank" rel="noopener noreferrer" class="cta white">
                  Código
                </a>
              )}
              <a href="/contratame" class="cta black">Quiero algo así</a>
              <a href="/" class="cta white">Inicio</a>
            </div>
          </article>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>
