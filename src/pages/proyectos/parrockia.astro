---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectGallery from "../../components/ProjectGallery.astro";

const title = "ParROCKia | Caso real de app y web para hostelería | ByteZagal";
const description =
  "Caso real para hostelería: carta visual, eventos, merchandising y panel de gestión con una experiencia más clara, usable y preparada para crecer.";

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://www.bytezagal.es/proyectos/parrockia#webpage",
  url: "https://www.bytezagal.es/proyectos/parrockia",
  name: title,
  description,
  isPartOf: {
    "@id": "https://www.bytezagal.es/#website"
  },
  about: {
    "@type": "SoftwareApplication",
    name: "ParROCKia",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://www.bytezagal.es/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Proyectos",
      item: "https://www.bytezagal.es/proyectos"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "ParROCKia",
      item: "https://www.bytezagal.es/proyectos/parrockia"
    }
  ]
};

const slides = [
  {
    src: "/parroHome.webp",
    alt: "Pantalla principal de ParROCKia con identidad visual del negocio",
    label: "Inicio",
    caption: "Portada con identidad propia y acceso claro a lo importante."
  },
  {
    src: "/parroEventos.webp",
    alt: "Sección de eventos de ParROCKia",
    label: "Eventos",
    caption: "Agenda y próximos eventos presentados de forma rápida y visible."
  },
  {
    src: "/parroJukeBox.webp",
    alt: "Función JukeBox dentro de ParROCKia",
    label: "JukeBox",
    caption: "Funcionalidad diferencial para reforzar experiencia y personalidad."
  },
  {
    src: "/parroPanel1.webp",
    alt: "Panel de administración de ParROCKia para gestionar contenido",
    label: "Panel 1",
    caption: "Gestión sencilla de contenidos para actualizar la web sin fricción."
  },
  {
    src: "/parroPanel2.webp",
    alt: "Segundo panel de administración de ParROCKia",
    label: "Panel 2",
    caption: "Operativa preparada para seguir creciendo sin depender de procesos torpes."
  },
  {
    src: "/parroUbicacion.webp",
    alt: "Bloque de ubicación e información útil de ParROCKia",
    label: "Ubicación",
    caption: "Información útil y localización accesible desde una navegación directa."
  }
] as const;

const chips = [
  "PWA",
  "Hostelería",
  "Eventos",
  "Merchandising",
  "Panel admin",
  "UX"
];

const valueCards = [
  {
    title: "Qué es",
    text: "Una solución digital para mostrar mejor el negocio, sus eventos y su propuesta sin perder personalidad."
  },
  {
    title: "Cómo ayuda",
    text: "Facilita consulta, gestión y actualización de contenido desde una experiencia más clara y práctica."
  },
  {
    title: "Qué transmite",
    text: "Criterio de producto, identidad visual y capacidad para convertir una web en herramienta real de negocio."
  }
];

const fitList = [
  "Negocios de hostelería con agenda, producto y comunidad.",
  "Marcas con personalidad que necesitan claridad sin verse genéricas.",
  "Proyectos que quieren gestionar contenido desde móvil u ordenador con facilidad."
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/proyectos/parrockia"
  jsonLd={[pageSchema, breadcrumbSchema]}
  bodyClass="text-slate-800"
>
  <section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex flex-wrap items-center gap-2">
        <li>
          <a
            href="/"
            class="inline-flex min-h-10 items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
          >
            Inicio
          </a>
        </li>
        <li>
          <a
            href="/proyectos"
            class="inline-flex min-h-10 items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
          >
            Proyectos
          </a>
        </li>
        <li>
          <span
            class="inline-flex min-h-10 items-center rounded-full border border-slate-900 bg-slate-900 px-4 py-2 text-sm font-semibold text-white"
            aria-current="page"
          >
            ParROCKia
          </span>
        </li>
      </ol>
    </nav>

    <section class="grid gap-10 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
          Caso publicado
        </p>

        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
          ParROCKia
        </h1>

        <p class="mt-5 text-lg leading-8 text-slate-600">
          App y web para una taberna con eventos, merchandising e información útil,
          pensada para enseñar mejor lo importante y facilitar la gestión del día a día.
        </p>

        <ul
          class="mt-6 flex flex-wrap gap-2"
          aria-label="Tecnologías y enfoque de ParROCKia"
        >
          {chips.map((item) => (
            <li class="chip">{item}</li>
          ))}
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="https://tabernaparrockia.com"
            target="_blank"
            rel="noopener noreferrer"
            class="cta black"
          >
            Ver proyecto en vivo
          </a>

          <a href="/contratame" class="cta white">
            Quiero algo así
          </a>

          <a href="/proyectos" class="cta white">
            Volver al hub
          </a>
        </div>
      </div>

      <ProjectGallery
        slides={slides}
        mode="desktop"
        ariaLabel="Galería del proyecto ParROCKia"
      />
    </section>

    <section class="mt-14">
      <div class="grid gap-6 md:grid-cols-3">
        {valueCards.map((card) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white/90 p-6 shadow-[0_18px_40px_rgba(15,23,42,0.05)]">
            <h2 class="text-xl font-bold tracking-tight text-slate-900">
              {card.title}
            </h2>
            <p class="mt-3 leading-7 text-slate-600">
              {card.text}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-14 grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      <article class="rounded-[2rem] border border-slate-200 bg-white/90 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">
          Enfoque del proyecto
        </h2>

        <div class="mt-5 space-y-4 text-base leading-8 text-slate-600">
          <p>
            ParROCKia mezcla identidad, agenda, producto y operativa. La clave aquí
            no era llenar la pantalla de ruido, sino ordenar la experiencia para que
            el negocio se entienda rápido y resulte fácil de consultar.
          </p>

          <p>
            Además de enseñar mejor la propuesta, el proyecto deja una base útil para
            publicar eventos, mover merchandising y gestionar contenido sin convertir
            cada cambio en una mini odisea administrativa.
          </p>

          <p>
            Es un buen ejemplo de solución digital para hostelería con personalidad,
            comunidad y necesidad real de visibilidad continua.
          </p>
        </div>
      </article>

      <aside class="rounded-[2rem] border border-slate-200 bg-white/90 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">
          Dónde encaja bien una solución así
        </h2>

        <ul class="mt-5 space-y-3 text-slate-600">
          {fitList.map((item) => (
            <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 leading-7">
              {item}
            </li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="mt-14">
      <div class="rounded-[2rem] border border-slate-900 bg-slate-900 px-6 py-8 text-white shadow-[0_18px_50px_rgba(15,23,42,0.16)] md:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-300">
          Siguiente paso
        </p>

        <h2 class="mt-3 text-3xl font-extrabold tracking-tight">
          Si tu negocio necesita una presencia útil y fácil de gestionar, hablemos
        </h2>

        <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
          Desde hostelería hasta productos con operativa real: la idea es construir
          una base clara, usable y preparada para crecer sin liarse la guitarra.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contratame" class="cta white">
            Cuéntame tu proyecto
          </a>
          <a href="/proyectos" class="cta ghost-light">
            Ver más casos
          </a>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
