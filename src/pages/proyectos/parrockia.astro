---
import "../../styles/globals.css";
import Seo from "../../components/Seo.astro";
import Footer from "../../components/Footer.astro";

const title = "ParROCKia | Caso real de web para hostelería | ByteZagal";
const description =
  "Caso real de presencia digital para hostelería: estructura más clara, navegación usable y una base preparada para crecer sin perder personalidad.";

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://bytezagal.es/proyectos/parrockia#webpage",
  url: "https://bytezagal.es/proyectos/parrockia",
  name: title,
  description,
  isPartOf: {
    "@id": "https://bytezagal.es/#website"
  },
  about: {
    "@type": "CreativeWork",
    name: "ParROCKia"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://bytezagal.es/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Proyectos",
      item: "https://bytezagal.es/proyectos"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "ParROCKia",
      item: "https://bytezagal.es/proyectos/parrockia"
    }
  ]
};
---

<html lang="es">
  <head>
    <Seo
      title={title}
      description={description}
      canonicalPath="/proyectos/parrockia"
      image="/parrockia.webp"
      jsonLd={[pageSchema, breadcrumbSchema]}
    />
  </head>

  <body class="bg-orbital text-slate-800">
    <main class="mx-auto max-w-5xl px-4 py-12 md:py-16">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
          <li>
            <a href="/" class="transition hover:text-slate-900">Inicio</a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <a href="/proyectos" class="transition hover:text-slate-900">Proyectos</a>
          </li>
          <li aria-hidden="true">/</li>
          <li class="font-medium text-slate-700">ParROCKia</li>
        </ol>
      </nav>

      <article class="rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-[0_18px_50px_rgba(15,23,42,0.08)] backdrop-blur md:p-10">
        <header class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
            Caso real · Hostelería
          </p>

          <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
            ParROCKia
          </h1>

          <p class="mt-5 text-lg leading-8 text-slate-600">
            Web para una taberna con identidad propia, pensada para enseñar mejor lo
            importante, facilitar la navegación y dejar una base digital más sólida
            para seguir creciendo sin perder carácter.
          </p>
        </header>

        <figure class="mt-10 overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 shadow-sm">
          <img
            src="/parrockia.webp"
            alt="Captura del proyecto web de ParROCKia"
            class="h-auto w-full object-cover"
            loading="eager"
            fetchpriority="high"
            width="1600"
            height="900"
          />
        </figure>

        <section class="mt-12 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
          <div>
            <h2 class="text-2xl font-bold text-slate-900">Qué necesitaba el negocio</h2>
            <p class="mt-4 leading-8 text-slate-600">
              ParROCKia es un negocio con personalidad clara y público propio. La web tenía
              que acompañar esa identidad sin caer en el ruido: enseñar bien la propuesta,
              facilitar la consulta desde móvil y dejar una presencia digital defendible.
            </p>
            <p class="mt-4 leading-8 text-slate-600">
              Aquí la clave no era “hacer una web bonita”, sino ordenar mejor la base:
              estructura, lectura, navegación y una presentación más clara para quien llega
              por primera vez.
            </p>
          </div>

          <aside class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
            <h2 class="text-lg font-bold text-slate-900">Tecnologías</h2>
            <ul class="mt-4 flex flex-wrap gap-2">
              <li class="chip">React</li>
              <li class="chip">Tailwind</li>
              <li class="chip">PHP (API)</li>
            </ul>

            <h2 class="mt-6 text-lg font-bold text-slate-900">Lo relevante aquí</h2>
            <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-600">
              <li>Presencia digital más clara para hostelería y eventos.</li>
              <li>Navegación usable desde móvil.</li>
              <li>Base preparada para crecer sin perder identidad.</li>
              <li>Proyecto visible y publicado.</li>
            </ul>
          </aside>
        </section>

        <section class="mt-12">
          <h2 class="text-2xl font-bold text-slate-900">Qué se trabajó</h2>

          <div class="mt-6 grid gap-4 md:grid-cols-3">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
              <h3 class="text-lg font-semibold text-slate-900">Estructura</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                Se reforzó la jerarquía de contenidos para que la información importante
                se entienda mejor y no quede enterrada.
              </p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
              <h3 class="text-lg font-semibold text-slate-900">Experiencia de uso</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                Se priorizó una navegación clara y cómoda desde móvil, donde muchas
                consultas reales suceden.
              </p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
              <h3 class="text-lg font-semibold text-slate-900">Base técnica</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                Se dejó una base más limpia y más fácil de mantener, evitando decisiones
                que complican crecer después.
              </p>
            </div>
          </div>
        </section>

        <section class="mt-12">
          <h2 class="text-2xl font-bold text-slate-900">Decisiones con criterio</h2>
          <ul class="mt-6 space-y-4 text-slate-600">
            <li class="rounded-2xl border border-slate-200 bg-white p-5 leading-8 shadow-sm">
              No inflar el proyecto con artificios visuales que resten claridad.
            </li>
            <li class="rounded-2xl border border-slate-200 bg-white p-5 leading-8 shadow-sm">
              Mantener la personalidad de marca sin sacrificar lectura ni usabilidad.
            </li>
            <li class="rounded-2xl border border-slate-200 bg-white p-5 leading-8 shadow-sm">
              Pensar la web como una herramienta de negocio, no como una pieza aislada.
            </li>
          </ul>
        </section>

        <section class="mt-12 rounded-3xl border border-slate-200 bg-slate-950 px-6 py-8 text-white md:px-8">
          <h2 class="text-2xl font-bold">Resultado que se puede defender</h2>
          <p class="mt-4 max-w-3xl leading-8 text-slate-200">
            El valor de este caso no está en enseñar fuegos artificiales, sino en demostrar
            criterio: una presencia digital más clara, más fácil de entender y mejor
            preparada para acompañar al negocio con menos fricción.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="https://tabernaparrockia.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-slate-100"
            >
              Ver proyecto en vivo
            </a>

            <a
              href="/contratame"
              class="inline-flex items-center justify-center rounded-full border border-white/20 px-5 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/10"
            >
              Quiero un diagnóstico parecido
            </a>
          </div>
        </section>

        <section class="mt-12">
          <h2 class="text-2xl font-bold text-slate-900">Servicios relacionados</h2>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            <a
              href="/servicios/digitalizacion"
              class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            >
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">
                Base digital y visibilidad
              </p>
              <h3 class="mt-2 text-lg font-bold text-slate-900">
                Digitalización de negocio
              </h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                Para negocios que necesitan una presencia más clara, más útil y mejor
                preparada para captar.
              </p>
            </a>

            <a
              href="/servicios/arreglos"
              class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            >
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">
                Rescate y estabilización
              </p>
              <h3 class="mt-2 text-lg font-bold text-slate-900">
                Arreglos de software
              </h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                Para webs o aplicaciones que ya existen y necesitan orden, mejora o una
                reconstrucción parcial sensata.
              </p>
            </a>
          </div>
        </section>

        <div class="mt-12 flex flex-wrap gap-3 border-t border-slate-200 pt-8">
          <a
            href="/proyectos"
            class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-3 font-semibold text-slate-900 transition hover:bg-slate-50"
          >
            ← Volver a proyectos
          </a>

          <a
            href="/#contacto"
            class="inline-flex items-center justify-center rounded-full bg-slate-950 px-5 py-3 font-semibold text-white transition hover:opacity-95"
          >
            Hablar sobre mi caso
          </a>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>
