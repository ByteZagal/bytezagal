---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectGallery from "../../components/ProjectGallery.astro";

const title = "FocoNauta | App de gestión para autónomos y operativa diaria | ByteZagal";
const description =
  "Caso de app para controlar clientes, gastos, facturas y operativa en menos pasos, con una experiencia clara y pensada para trabajar sin fricción.";

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://bytezagal.es/proyectos/foconauta#webpage",
  url: "https://bytezagal.es/proyectos/foconauta",
  name: title,
  description,
  isPartOf: {
    "@id": "https://bytezagal.es/#website"
  },
  about: {
    "@type": "SoftwareApplication",
    name: "FocoNauta",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://bytezagal.es/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Proyectos",
      item: "https://bytezagal.es/proyectos"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "FocoNauta",
      item: "https://bytezagal.es/proyectos/foconauta"
    }
  ]
};

const slides = [
  {
    src: "/focoDashBoard.webp",
    alt: "Dashboard principal de FocoNauta para control de operativa y finanzas",
    label: "Dashboard",
    caption: "Vista general para entender el negocio de un vistazo y decidir más rápido."
  },
  {
    src: "/focoClientes.webp",
    alt: "Pantalla de clientes de FocoNauta",
    label: "Clientes",
    caption: "Gestión de clientes ordenada para no perder contexto ni tiempo entre gestiones."
  },
  {
    src: "/focoFacturas.webp",
    alt: "Pantalla de facturas de FocoNauta",
    label: "Facturas",
    caption: "Control de facturación en una interfaz clara y orientada a trabajar sin rodeos."
  },
  {
    src: "/focoFacturaDetalle.webp",
    alt: "Detalle de factura dentro de FocoNauta",
    label: "Detalle",
    caption: "Acceso rápido al detalle para revisar, corregir o consultar sin laberintos."
  },
  {
    src: "/focoGastos.webp",
    alt: "Pantalla de gastos de FocoNauta",
    label: "Gastos",
    caption: "Seguimiento de gastos para tener una visión más limpia del día a día financiero."
  }
] as const;

const chips = [
  "PWA",
  "Facturación",
  "Clientes",
  "Gastos",
  "TypeScript",
  "Operativa real"
];

const valueCards = [
  {
    title: "Qué es",
    text: "Una app para concentrar clientes, facturas y gastos en una sola experiencia más clara y usable."
  },
  {
    title: "Cómo ayuda",
    text: "Reduce pasos en gestiones cotidianas y da contexto rápido para trabajar con menos fricción."
  },
  {
    title: "Qué transmite",
    text: "Criterio de producto, orden visual y capacidad para convertir papeleo en una herramienta útil."
  }
];

const fitList = [
  "Autónomos que quieren controlar mejor su operativa sin perder media mañana en gestión.",
  "Pequeños equipos que necesitan clientes, facturas y gastos más ordenados.",
  "Negocios que quieren menos caos administrativo y más claridad para tomar decisiones."
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/proyectos/foconauta"
  jsonLd={[pageSchema, breadcrumbSchema]}
  bodyClass="text-slate-800"
>
  <section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex flex-wrap items-center gap-2">
        <li>
          <a
            href="/"
            class="inline-flex min-h-10 items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
          >
            Inicio
          </a>
        </li>
        <li>
          <a
            href="/proyectos"
            class="inline-flex min-h-10 items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
          >
            Proyectos
          </a>
        </li>
        <li>
          <span
            class="inline-flex min-h-10 items-center rounded-full border border-slate-900 bg-slate-900 px-4 py-2 text-sm font-semibold text-white"
            aria-current="page"
          >
            FocoNauta
          </span>
        </li>
      </ol>
    </nav>

    <section class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
          Caso privado
        </p>

        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
          FocoNauta
        </h1>

        <p class="mt-5 text-lg leading-8 text-slate-600">
          App para gestionar clientes, facturas y gastos con menos pasos, menos ruido
          y una operativa mucho más clara para el día a día.
        </p>

        <ul
          class="mt-6 flex flex-wrap gap-2"
          aria-label="Tecnologías y enfoque de FocoNauta"
        >
          {chips.map((item) => (
            <li class="chip">{item}</li>
          ))}
        </ul>

        <p class="mt-6 rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-sm leading-7 text-slate-600 shadow-[0_12px_30px_rgba(15,23,42,0.05)]">
          Proyecto en fase privada. Esta demo visual enseña el criterio de producto,
          la estructura y la experiencia de uso sin exponer información sensible ni datos reales.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contratame" class="cta black">
            Quiero algo así
          </a>

          <a href="/proyectos" class="cta white">
            Volver al hub
          </a>
        </div>
      </div>

      <ProjectGallery
        slides={slides}
        mode="desktop"
        ariaLabel="Galería del proyecto FocoNauta"
      />
    </section>

    <section class="mt-14">
      <div class="grid gap-6 md:grid-cols-3">
        {valueCards.map((card) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white/90 p-6 shadow-[0_18px_40px_rgba(15,23,42,0.05)]">
            <h2 class="text-xl font-bold tracking-tight text-slate-900">
              {card.title}
            </h2>
            <p class="mt-3 leading-7 text-slate-600">
              {card.text}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-14 grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      <article class="rounded-[2rem] border border-slate-200 bg-white/90 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">
          Enfoque del proyecto
        </h2>

        <div class="mt-5 space-y-4 text-base leading-8 text-slate-600">
          <p>
            FocoNauta nace de una fricción muy común: demasiadas gestiones pequeñas,
            demasiados cambios de contexto y demasiado tiempo perdido entre facturas,
            clientes, gastos y tareas administrativas.
          </p>

          <p>
            La propuesta es reunir esa operativa en una experiencia más limpia y directa,
            donde consultar, revisar o registrar algo importante no se convierta en una excursión.
          </p>

          <p>
            Es el tipo de producto que no solo ordena pantallas: ordena el trabajo.
            Y cuando eso pasa, el negocio gana claridad, velocidad y control.
          </p>
        </div>
      </article>

      <aside class="rounded-[2rem] border border-slate-200 bg-white/90 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">
          Dónde encaja bien una solución así
        </h2>

        <ul class="mt-5 space-y-3 text-slate-600">
          {fitList.map((item) => (
            <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 leading-7">
              {item}
            </li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="mt-14">
      <div class="rounded-[2rem] border border-slate-900 bg-slate-900 px-6 py-8 text-white shadow-[0_18px_50px_rgba(15,23,42,0.16)] md:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-300">
          Siguiente paso
        </p>

        <h2 class="mt-3 text-3xl font-extrabold tracking-tight">
          Si quieres menos fricción en tu gestión diaria, hablemos
        </h2>

        <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
          Desde autónomos hasta pequeños negocios con operativa real: la meta es
          trabajar con más orden, menos clics inútiles y una base preparada para crecer.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contratame" class="cta white">
            Cuéntame tu proyecto
          </a>
          <a href="/proyectos" class="cta ghost-light">
            Ver más casos
          </a>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
