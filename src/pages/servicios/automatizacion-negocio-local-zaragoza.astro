---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FaqService from "../../components/FaqService.astro";
import { org, website, localBusiness } from "../../seo/structured";

const title = "Automatización para negocio local en Zaragoza | Procesos, avisos e integraciones | ByteZagal";
const description =
  "Automatización para negocio local en Zaragoza: formularios, avisos, flujos, integraciones y procesos digitales más ordenados para ahorrar tiempo y reducir trabajo manual.";

const painPoints = [
  {
    title: "Trabajo repetitivo",
    text: "Mensajes, avisos, seguimientos o tareas manuales que se repiten demasiado y consumen tiempo sin aportar valor."
  },
  {
    title: "Información dispersa",
    text: "Datos en varios sitios, pasos poco claros y una operativa que depende demasiado de recordar cosas."
  },
  {
    title: "Procesos frágiles",
    text: "Lead forms, contactos, avisos o pasos internos que funcionan “más o menos” hasta que empiezan a fallar."
  }
] as const;

const solutions = [
  {
    title: "Formularios y captación",
    text: "Entradas más claras, datos mejor organizados y menos pérdidas por procesos mal montados."
  },
  {
    title: "Avisos y seguimiento",
    text: "Notificaciones, recordatorios y pasos automáticos para no depender de perseguir tareas a mano."
  },
  {
    title: "Integraciones útiles",
    text: "Conexiones razonables entre herramientas para recortar fricción sin vender magia ni complejidad innecesaria."
  }
] as const;

const relatedLinks = [
  {
    title: "Ver desarrollo de apps",
    text: "Si necesitas una capa con interfaz o panel interno.",
    href: "/servicios/desarrollo-apps-zaragoza"
  },
  {
    title: "Ver digitalización",
    text: "Si primero necesitas una base digital más ordenada.",
    href: "/servicios/digitalizacion"
  },
  {
    title: "Ver contratación",
    text: "Para valorar si tu caso pide automatización, app o web.",
    href: "/contratame"
  }
] as const;

const faqs = [
  {
    question: "¿Qué tipo de automatización haces para negocio local?",
    answer:
      "Formularios, avisos, seguimientos, procesos internos simples, integraciones y mejoras que reduzcan pasos manuales y errores repetidos."
  },
  {
    question: "¿Esto sustituye una app?",
    answer:
      "No siempre. A veces basta con automatizar procesos; otras veces conviene una herramienta con interfaz. Depende del caso."
  },
  {
    question: "¿Sirve solo para Zaragoza?",
    answer:
      "La página está orientada a Zaragoza por intención local, pero este tipo de trabajo también encaja en remoto para otros proyectos."
  }
] as const;

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://www.bytezagal.es/#webpage-automatizacion-zaragoza",
  url: "https://www.bytezagal.es/servicios/automatizacion-negocio-local-zaragoza",
  name: title,
  description,
  inLanguage: "es-ES",
  isPartOf: { "@id": "https://www.bytezagal.es/#website" },
  about: { "@id": "https://www.bytezagal.es/#professional-service" }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Automatización para negocio local en Zaragoza",
  serviceType: "Automatización de procesos",
  areaServed: ["Zaragoza"],
  provider: { "@id": "https://www.bytezagal.es/#professional-service" },
  url: "https://www.bytezagal.es/servicios/automatizacion-negocio-local-zaragoza",
  description
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://www.bytezagal.es/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Servicios",
      item: "https://www.bytezagal.es/contratame"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Automatización negocio local Zaragoza",
      item: "https://www.bytezagal.es/servicios/automatizacion-negocio-local-zaragoza"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer
    }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/servicios/automatizacion-negocio-local-zaragoza"
  image="/bytezagal-og.home.webp"
  jsonLd={[org, website, localBusiness, pageSchema, serviceSchema, breadcrumbSchema, faqSchema]}
  bodyClass="text-slate-800"
>
  <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <header class="mx-auto max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
        Automatización Zaragoza
      </p>

      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
        Automatización para negocio local en Zaragoza
      </h1>

      <p class="mt-5 text-lg leading-8 text-slate-600">
        Para negocios que están perdiendo tiempo en tareas repetitivas, procesos poco
        claros o pasos manuales que ya no tienen sentido. La idea es ordenar y aligerar,
        no vender humo.
      </p>
    </header>

    <section class="mt-12 grid gap-6 md:grid-cols-3">
      {painPoints.map((item) => (
        <article class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-[0_18px_50px_rgba(15,23,42,0.08)] backdrop-blur">
          <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">
            {item.title}
          </h2>
          <p class="mt-4 leading-8 text-slate-600">
            {item.text}
          </p>
        </article>
      ))}
    </section>

    <section class="mt-14 rounded-[2rem] border border-slate-200 bg-white/95 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)] backdrop-blur md:p-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
          Qué puede resolverse
        </p>

        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900">
          Automatizar para recortar fricción, no para complicar más
        </h2>

        <p class="mt-4 text-base leading-8 text-slate-600">
          A veces con cuatro pasos bien pensados se elimina mucho ruido. Lo importante
          es entender qué proceso merece automatización y cuál no.
        </p>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {solutions.map((item) => (
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/90 p-5">
            <h3 class="text-xl font-bold tracking-tight text-slate-900">
              {item.title}
            </h3>
            <p class="mt-3 leading-7 text-slate-600">
              {item.text}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-16">
      <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">
        Enlaces relacionados
      </h2>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {relatedLinks.map((item) => (
          <article class="rounded-[1.5rem] border border-slate-200 bg-white/95 p-5 shadow-[0_12px_30px_rgba(15,23,42,0.05)]">
            <h3 class="text-xl font-bold text-slate-900">{item.title}</h3>
            <p class="mt-3 leading-7 text-slate-600">{item.text}</p>
            <div class="mt-5">
              <a href={item.href} class="cta white">
                Abrir
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <FaqService faqs={[...faqs]} />

    <section class="mt-16 rounded-[2rem] border border-slate-900 bg-slate-900 px-6 py-8 text-white shadow-[0_18px_50px_rgba(15,23,42,0.16)] md:px-8">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-300">
        Siguiente paso
      </p>

      <h2 class="mt-3 text-3xl font-extrabold tracking-tight">
        Si tu operativa tiene demasiado trabajo manual, hablemos
      </h2>

      <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
        Cuéntame qué pasos se repiten, dónde se pierde tiempo y qué herramientas usas
        ahora. A partir de ahí vemos si conviene automatizar, crear una herramienta
        o simplificar el proceso.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/contratame" class="cta white">
          Ir a contratación
        </a>
        <a href="/servicios/desarrollo-apps-zaragoza" class="cta ghost-light">
          Ver apps Zaragoza
        </a>
      </div>
    </section>
  </section>
</BaseLayout>
