---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FaqService from "../../components/FaqService.astro";
import { MessageCircle, Globe, Search, Workflow } from "lucide-astro";
import { org, website, localBusiness } from "../../seo/structured";

const title = "Digitalización de negocio y base digital | ByteZagal";
const description =
  "Web corporativa, base SEO, estructura digital y automatización útil para negocio. Una presencia más seria, clara y preparada para captar y crecer.";

const whatsappBase = "https://wa.me/34650850163?text=";

const planes = [
  {
    name: "Base clara",
    price: "Desde 690 €",
    feat: [
      "Landing o web corporativa ligera",
      "Copy estructurado y base SEO",
      "Analítica y contacto listos para captar"
    ],
    whatsappLabel: "la base clara de digitalización"
  },
  {
    name: "Presencia sólida",
    price: "Desde 1.190 €",
    feat: [
      "Web multi-sección más completa",
      "SEO técnico y arquitectura más seria",
      "Soporte para campañas, contenidos y crecimiento"
    ],
    whatsappLabel: "la presencia sólida de digitalización"
  },
  {
    name: "Digitalización a medida",
    price: "Desde 1.890 €",
    feat: [
      "Automatización útil para negocio",
      "Flujos y procesos mejor conectados",
      "Base preparada para evolucionar sin caos"
    ],
    whatsappLabel: "una digitalización a medida"
  }
] as const;

const faqs = [
  {
    question: "¿Cuánto cuesta digitalizar un negocio?",
    answer:
      "Como referencia pública, la entrada está desde 690 €. El presupuesto final depende de si hablamos de una base web simple, una presencia más completa o una capa de automatización mayor."
  },
  {
    question: "¿Qué incluye este servicio?",
    answer:
      "Puede incluir web corporativa, mejora de estructura, SEO técnico, analítica, automatización ligera y una base más ordenada para captar y operar mejor."
  },
  {
    question: "¿Trabajas también en remoto?",
    answer:
      "Sí. Aunque el foco comercial está en Zaragoza, trabajo también en remoto para clientes de toda España."
  }
] as const;

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://bytezagal.es/#webpage-digitalizacion",
  url: "https://bytezagal.es/servicios/digitalizacion",
  name: title,
  description,
  inLanguage: "es-ES",
  isPartOf: { "@id": "https://bytezagal.es/#website" },
  about: { "@id": "https://bytezagal.es/#professional-service" }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Digitalización de negocio y base digital",
  serviceType: "Digitalización de negocio",
  areaServed: ["Zaragoza", "España"],
  provider: { "@id": "https://bytezagal.es/#professional-service" },
  url: "https://bytezagal.es/servicios/digitalizacion",
  description
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://bytezagal.es/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Servicios",
      item: "https://bytezagal.es/contratame"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Digitalización",
      item: "https://bytezagal.es/servicios/digitalizacion"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer
    }
  }))
};

const relatedProjects = [
  {
    title: "TxoriOn",
    description: "Producto publicado con utilidad clara, estructura limpia y recorrido real.",
    href: "/proyectos/txorion"
  },
  {
    title: "ParROCKia",
    description: "Caso real donde la estructura, el contenido y la claridad pesan más que el adorno.",
    href: "/proyectos/parrockia"
  }
] as const;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/servicios/digitalizacion"
  image="/bytezagal-og.home.webp"
  jsonLd={[org, website, localBusiness, pageSchema, serviceSchema, breadcrumbSchema, faqSchema]}
  bodyClass="text-slate-800"
>
  <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <header class="mx-auto max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
        Digitalización
      </p>

      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
        Digitalización de negocio y base digital útil
      </h1>

      <p class="mt-5 text-lg leading-8 text-slate-600">
        Para negocios que necesitan una presencia más seria, una base web más útil
        y una estructura digital preparada para captar y trabajar mejor. Trabajo
        desde Zaragoza y también en remoto para toda España.
      </p>
    </header>

    <section class="mt-10 grid gap-6 md:grid-cols-3">
      {planes.map((plan) => (
        <article class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-[0_18px_50px_rgba(15,23,42,0.08)] backdrop-blur">
          <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">
            {plan.name}
          </h2>

          <p class="mt-4 text-3xl font-extrabold text-slate-900">
            {plan.price}
          </p>

          <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600">
            {plan.feat.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <div class="mt-6 flex flex-col gap-3">
            <a
              href={`${whatsappBase}${encodeURIComponent(`Hola ByteZagal, quiero hablar sobre ${plan.whatsappLabel}.`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-emerald-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-700 focus-visible:ring-offset-2"
            >
              <MessageCircle class="h-4 w-4" />
              Escribir por WhatsApp
            </a>

            <a href="/contratame" class="cta white text-center">
              Ver otras vías
            </a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-14 rounded-[2rem] border border-slate-200 bg-white/95 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)] backdrop-blur md:p-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
          Qué resuelvo aquí
        </p>

        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900">
          Menos presencia de adorno, más base útil para negocio
        </h2>

        <p class="mt-4 text-base leading-8 text-slate-600">
          La idea no es solo “tener web”. Es tener una estructura clara, entendible,
          con una base SEO correcta y una presencia que sí ayude a captar y crecer.
        </p>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/90 p-5">
          <Globe class="h-6 w-6 text-slate-900" />
          <h3 class="mt-4 text-xl font-bold tracking-tight text-slate-900">
            Web útil
          </h3>
          <p class="mt-3 leading-7 text-slate-600">
            Landing o web corporativa pensada para explicar bien lo que haces y facilitar el siguiente paso.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/90 p-5">
          <Search class="h-6 w-6 text-slate-900" />
          <h3 class="mt-4 text-xl font-bold tracking-tight text-slate-900">
            Base SEO sólida
          </h3>
          <p class="mt-3 leading-7 text-slate-600">
            Arquitectura, indexación, metadatos y una base semántica más seria desde el principio.
          </p>
        </article>

        <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/90 p-5">
          <Workflow class="h-6 w-6 text-slate-900" />
          <h3 class="mt-4 text-xl font-bold tracking-tight text-slate-900">
            Operativa más limpia
          </h3>
          <p class="mt-3 leading-7 text-slate-600">
            Automatización razonable y menos pasos tontos en tareas que se repiten demasiado.
          </p>
        </article>
      </div>
    </section>

    <FaqService faqs={[...faqs]} />

    <section class="mt-16">
      <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">
        Casos relacionados
      </h2>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {relatedProjects.map((project) => (
          <article class="rounded-[1.5rem] border border-slate-200 bg-white/95 p-5 shadow-[0_12px_30px_rgba(15,23,42,0.05)]">
            <h3 class="text-xl font-bold text-slate-900">{project.title}</h3>
            <p class="mt-3 leading-7 text-slate-600">{project.description}</p>
            <div class="mt-5">
              <a href={project.href} class="cta white">
                Ver proyecto
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <div class="mt-12 text-center">
      <a href="/" class="cta white">← Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
