---
import BaseLayout from "../layouts/BaseLayout.astro";
import FaqService from "../components/FaqService.astro";
import { org, website, localBusiness } from "../seo/structured";

const title = "Desarrollador web en Zaragoza para negocios y marcas | ByteZagal";
const description =
  "Desarrollo web en Zaragoza con foco en rendimiento, claridad, SEO técnico y negocio. Webs, rescate web, apps y mejoras digitales para proyectos que necesitan una base seria.";

const entryPoints = [
  {
    title: "Desarrollo web en Zaragoza",
    text: "Para negocios, marcas y proyectos que necesitan una web clara, rápida y preparada para captar.",
    href: "/servicios/desarrollo-web-zaragoza"
  },
  {
    title: "Rescate web en Zaragoza",
    text: "Para webs lentas, rotas o mal planteadas que necesitan orden, criterio técnico y una hoja de ruta sensata.",
    href: "/servicios/rescate-web-zaragoza"
  },
  {
    title: "Desarrollo de apps en Zaragoza",
    text: "Para herramientas internas, paneles y pequeñas apps que ahorran tiempo y ordenan procesos.",
    href: "/servicios/desarrollo-apps-zaragoza"
  }
] as const;

const strengths = [
  {
    title: "Menos adorno, más base útil",
    text: "La web tiene que explicar bien, cargar rápido, estar bien planteada y ayudarte a vender o trabajar mejor."
  },
  {
    title: "SEO técnico desde el principio",
    text: "Arquitectura, indexación, metadatos, enlazado interno y estructura clara para no construir sobre arena."
  },
  {
    title: "Criterio técnico y comercial",
    text: "No se trata solo de desarrollar. Se trata de priorizar lo que más impacto tiene con el menor caos posible."
  }
] as const;

const relatedLinks = [
  {
    title: "Ver proyectos y casos reales",
    text: "Para comprobar criterio, ejecución y recorrido real.",
    href: "/proyectos"
  },
  {
    title: "Ver página remoto España",
    text: "Si tu proyecto no está en Zaragoza, también trabajo en remoto.",
    href: "/espana-remoto"
  },
  {
    title: "Ir a contratación",
    text: "Para explicar tu caso y ver la vía más sensata.",
    href: "/contratame"
  }
] as const;

const faqs = [
  {
    question: "¿Trabajas solo en Zaragoza?",
    answer:
      "No. El foco comercial está en Zaragoza, pero también trabajo en remoto para clientes de toda España."
  },
  {
    question: "¿Qué tipo de proyectos haces en Zaragoza?",
    answer:
      "Webs corporativas, landings, rescate de webs existentes, mejoras de SEO técnico, desarrollo de apps pequeñas y automatización útil para negocio."
  },
  {
    question: "¿También arreglas webs ya hechas?",
    answer:
      "Sí. Muchas veces no hace falta rehacerlo todo. Primero reviso la base técnica y después planteo la vía más sensata."
  }
] as const;

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://bytezagal.es/#webpage-zaragoza",
  url: "https://bytezagal.es/zaragoza",
  name: title,
  description,
  inLanguage: "es-ES",
  isPartOf: { "@id": "https://bytezagal.es/#website" },
  about: { "@id": "https://bytezagal.es/#professional-service" }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://bytezagal.es/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Zaragoza",
      item: "https://bytezagal.es/zaragoza"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer
    }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/zaragoza"
  image="/bytezagal-og.home.webp"
  jsonLd={[org, website, localBusiness, pageSchema, breadcrumbSchema, faqSchema]}
  bodyClass="text-slate-800"
>
  <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <header class="mx-auto max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
        Zaragoza
      </p>

      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
        Desarrollo web en Zaragoza con foco en claridad, rendimiento y negocio
      </h1>

      <p class="mt-5 text-lg leading-8 text-slate-600">
        Trabajo desde Zaragoza ayudando a negocios, marcas y proyectos que necesitan
        una web más seria, una base técnica más limpia o una solución digital que
        no complique más las cosas. Menos escaparate vacío, más estructura útil.
      </p>
    </header>

    <section class="mt-12 grid gap-6 md:grid-cols-3">
      {entryPoints.map((item) => (
        <article class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-[0_18px_50px_rgba(15,23,42,0.08)] backdrop-blur">
          <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">
            {item.title}
          </h2>

          <p class="mt-4 leading-8 text-slate-600">
            {item.text}
          </p>

          <div class="mt-6">
            <a href={item.href} class="cta black">
              Ver página
            </a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-14 rounded-[2rem] border border-slate-200 bg-white/95 p-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)] backdrop-blur md:p-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">
          Cómo enfoco el trabajo
        </p>

        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900">
          Una web profesional no debería depender del maquillaje
        </h2>

        <p class="mt-4 text-base leading-8 text-slate-600">
          La idea no es solo “tener presencia”. La idea es tener una base que
          explique bien lo que haces, cargue rápido, se pueda mantener y ayude
          de verdad a captar o trabajar mejor.
        </p>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {strengths.map((item) => (
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/90 p-5">
            <h3 class="text-xl font-bold tracking-tight text-slate-900">
              {item.title}
            </h3>
            <p class="mt-3 leading-7 text-slate-600">
              {item.text}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-16">
      <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">
        Siguientes puertas de entrada
      </h2>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {relatedLinks.map((item) => (
          <article class="rounded-[1.5rem] border border-slate-200 bg-white/95 p-5 shadow-[0_12px_30px_rgba(15,23,42,0.05)]">
            <h3 class="text-xl font-bold text-slate-900">{item.title}</h3>
            <p class="mt-3 leading-7 text-slate-600">{item.text}</p>
            <div class="mt-5">
              <a href={item.href} class="cta white">
                Abrir
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <FaqService faqs={[...faqs]} />

    <section class="mt-16 rounded-[2rem] border border-slate-900 bg-slate-900 px-6 py-8 text-white shadow-[0_18px_50px_rgba(15,23,42,0.16)] md:px-8">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-300">
        Siguiente paso
      </p>

      <h2 class="mt-3 text-3xl font-extrabold tracking-tight">
        Si tu proyecto necesita una base digital más seria, hablemos
      </h2>

      <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
        Cuéntame qué tienes, qué falla y qué objetivo persigues. Te diré por dónde
        conviene empezar y qué merece tocar primero.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/contratame" class="cta white">
          Ir a contratación
        </a>
        <a href="/proyectos" class="cta ghost-light">
          Ver proyectos
        </a>
      </div>
    </section>
  </section>
</BaseLayout>
