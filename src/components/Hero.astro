---
import Seo from "../components/Seo.astro";

const title = "Pedro Aguilar";
const description = "Desarrollo webs claras, rápidas y accesibles para pymes de Vitoria-Gasteiz.";
const avatar = "/yo.webp";
const WHATSAPP = "https://wa.me/34650850163?text=Hola%20Pedro,%20quiero%20hablar%20sobre%20mi%20web.";
---
<Seo title={title} description={description} canonicalPath="/" image={avatar} />

<section class="relative pt-20 pb-16 text-center">
  <!-- Halo suave -->
  <div class="absolute left-1/2 top-10 -z-10 h-40 w-40 -translate-x-1/2 rounded-full bg-[radial-gradient(circle_at_center,rgba(247,147,30,0.22),transparent_60%)]" data-reveal></div>

  <!-- Avatar -->
  <button
    id="openAvatar"
    type="button"
    class="mx-auto mb-6 h-24 w-24 overflow-hidden rounded-full ring-4 ring-white shadow-lg focus:outline-none focus-visible:ring-4 focus-visible:ring-orange-500"
    aria-haspopup="dialog"
    aria-controls="heroAvatarModal"
    aria-label="Ver foto ampliada"
    data-reveal
  >
    <img
      src={avatar}
      alt="Pedro Aguilar, desarrollador web en Vitoria-Gasteiz"
      width="96" height="96" loading="eager" fetchpriority="high"
      class="h-24 w-24 object-cover transition-transform duration-300 will-change-transform hover:scale-105"
    />
  </button>

  <!-- Título y subtítulo -->
  <div class="mx-auto max-w-3xl px-4">
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-slate-900" data-reveal>
      {title}
    </h1>
    <p class="mt-3 text-lg md:text-xl text-slate-600" data-reveal data-reveal-delay="80">
      Desarrollo webs <strong>claras</strong>, <strong>rápidas</strong> y <strong>accesibles</strong> para pymes de Vitoria-Gasteiz.
    </p>

    <!-- CTAs -->
    <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3" data-reveal-stagger>
      <a href="/#contacto" class="inline-flex items-center justify-center rounded-full px-5 py-3 bg-black text-white font-semibold hover:opacity-90 transition">
        Contrátame
      </a>
      <a href="/proyectos" class="inline-flex items-center justify-center rounded-full px-5 py-3 border border-slate-300 font-semibold hover:bg-slate-50 transition">
        Ver proyectos
      </a>
      <a href={WHATSAPP} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full px-5 py-3 border border-slate-300 font-semibold hover:bg-slate-50 transition">
        WhatsApp
      </a>
    </div>
  </div>

  <!-- Modal circular pequeño -->
  <dialog id="heroAvatarModal" class="rounded-2xl backdrop:bg-black/50 p-0">
    <div class="relative flex items-center justify-center p-6">
      <button id="closeAvatar" class="absolute right-3 top-3 z-10 rounded-full bg-black/70 px-3 py-1 text-white text-sm" aria-label="Cerrar">
        Cerrar ✕
      </button>
      <img
        src={avatar}
        alt="Foto de Pedro Aguilar ampliada"
        width="320" height="320"
        class="w-[min(72vw,320px)] aspect-square rounded-full ring-4 ring-white shadow-2xl object-cover"
        loading="eager"
      />
    </div>
  </dialog>

  <script is:inline>
    (function(){
      const openBtn = document.getElementById('openAvatar');
      const dlg = document.getElementById('heroAvatarModal');
      const closeBtn = document.getElementById('closeAvatar');
      if(openBtn && dlg instanceof HTMLDialogElement){
        openBtn.addEventListener('click', ()=> dlg.showModal());
      }
      if(closeBtn && dlg instanceof HTMLDialogElement){
        closeBtn.addEventListener('click', ()=> dlg.close());
      }
    })();
  </script>
</section>
