---
const heading = "Pedro Aguilar";
const avatar = "/yo.webp";
const WHATSAPP = "https://wa.me/34650850163?text=Hola%20Pedro,%20quiero%20hablar%20sobre%20mi%20web.";
---

<section class="relative pt-20 pb-16 text-center">
  <!-- Halo suave -->
  <div class="absolute left-1/2 top-10 -z-10 h-40 w-40 -translate-x-1/2 rounded-full bg-[radial-gradient(circle_at_center,rgba(247,147,30,0.22),transparent_60%)]" data-reveal></div>

  <!-- Avatar -->
  <button
    id="openAvatar"
    type="button"
    class="mx-auto mb-6 h-24 w-24 overflow-hidden rounded-full ring-4 ring-white shadow-lg focus:outline-none focus-visible:ring-4 focus-visible:ring-orange-500"
    aria-haspopup="dialog"
    aria-controls="heroAvatarModal"
    aria-label="Ver foto ampliada"
    data-reveal
  >
    <img
      src={avatar}
      alt="Pedro Aguilar, desarrollador web en Vitoria-Gasteiz"
      width="96"
      height="96"
      loading="eager"
      fetchpriority="high"
      class="h-24 w-24 object-cover transition-transform duration-300 will-change-transform hover:scale-105"
    />
  </button>

  <!-- Título y subtítulo -->
  <div class="mx-auto max-w-3xl px-4">
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-slate-900" data-reveal>
      {heading}
    </h1>

    <p class="mt-3 text-lg md:text-xl text-slate-600" data-reveal data-reveal-delay="80">
      Desarrollo webs <strong>claras</strong>, <strong>rápidas</strong> y <strong>accesibles</strong> para pymes de Vitoria-Gasteiz.
    </p>

    <!-- CTAs -->
    <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row" data-reveal-stagger>
      <a
        href="/#contacto"
        class="inline-flex items-center justify-center rounded-full bg-black px-5 py-3 font-semibold text-white transition hover:opacity-90"
      >
        Contrátame
      </a>

      <a
        href="/proyectos"
        class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-3 font-semibold transition hover:bg-slate-50"
      >
        Ver proyectos
      </a>

      <a
        href={WHATSAPP}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-3 font-semibold transition hover:bg-slate-50"
      >
        WhatsApp
      </a>
    </div>
  </div>

  <!-- Modal circular pequeño -->
  <dialog id="heroAvatarModal" class="rounded-2xl p-0 backdrop:bg-black/50">
    <div class="relative flex items-center justify-center p-6">
      <button
        id="closeAvatar"
        class="absolute right-3 top-3 z-10 rounded-full bg-black/70 px-3 py-1 text-sm text-white"
        aria-label="Cerrar"
      >
        Cerrar ✕
      </button>

      <img
        src={avatar}
        alt="Foto de Pedro Aguilar ampliada"
        width="320"
        height="320"
        class="aspect-square w-[min(72vw,320px)] rounded-full object-cover ring-4 ring-white shadow-2xl"
        loading="eager"
      />
    </div>
  </dialog>

  <script is:inline>
    (() => {
      const openBtn = document.getElementById("openAvatar");
      const dialog = document.getElementById("heroAvatarModal");
      const closeBtn = document.getElementById("closeAvatar");

      if (openBtn && dialog instanceof HTMLDialogElement) {
        openBtn.addEventListener("click", () => dialog.showModal());
      }

      if (closeBtn && dialog instanceof HTMLDialogElement) {
        closeBtn.addEventListener("click", () => dialog.close());
      }
    })();
  </script>
</section>
