---
---
<div class="flex flex-col items-center justify-center w-full h-full gap-3">
  <input type="file" accept="image/png,image/jpeg" class="hidden webp-input" />
  <button class="cta white text-sm px-3 py-1.5 webp-upload">Subir archivo</button>

  <div class="relative w-full flex items-center justify-center bg-slate-100 rounded p-2 min-h-[150px]">
    <img class="max-h-40 rounded preview hidden" alt="preview" />
    <div class="text-slate-500 text-sm empty-msg">Ningún archivo seleccionado</div>
  </div>

  <button class="cta black text-sm px-3 py-1.5 webp-convert hidden">Convertir a WebP</button>
  <a class="cta white text-sm px-3 py-1.5 webp-download hidden">Descargar WebP</a>
  <progress max="100" value="0" class="w-full h-2 hidden progress"></progress>
</div>

<script is:inline>
(() => {
  const root = document.currentScript.closest("div");
  const input = root.querySelector(".webp-input");
  const uploadBtn = root.querySelector(".webp-upload");
  const convertBtn = root.querySelector(".webp-convert");
  const dl = root.querySelector(".webp-download");
  const preview = root.querySelector(".preview");
  const emptyMsg = root.querySelector(".empty-msg");
  const progress = root.querySelector(".progress");
  const canvas = document.createElement("canvas");
  const ctx = canvas.getContext("2d");
  let img;

  uploadBtn.addEventListener("click", () => input.click());

  input.addEventListener("change", (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      img = new Image();
      img.onload = () => {
        canvas.width = img.width;
        canvas.height = img.height;
        ctx.drawImage(img, 0, 0);
        preview.src = img.src;
        preview.classList.remove("hidden");
        emptyMsg.classList.add("hidden");
        convertBtn.classList.remove("hidden");
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  });

  convertBtn.addEventListener("click", () => {
    if (!img) return;
    progress.classList.remove("hidden");
    progress.value = 0;
    let val = 0;
    const interval = setInterval(() => {
      val += 20;
      progress.value = val;
      if (val >= 100) {
        clearInterval(interval);
        canvas.toBlob(
          (blob) => {
            const url = URL.createObjectURL(blob);
            dl.href = url;
            dl.download = "convertido.webp";
            dl.classList.remove("hidden");
            dl.click();
            progress.classList.add("hidden");
          },
          "image/webp",
          0.9
        );
      }
    }, 300);
  });
})();
</script>
