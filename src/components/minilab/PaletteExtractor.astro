---
---
<div class="flex flex-col items-center justify-center w-full gap-4">
  <input type="file" accept="image/*" class="hidden palette-input" />
  <button class="cta white text-sm px-3 py-1.5 palette-upload">Subir imagen</button>

  <canvas class="palette-canvas hidden max-h-60 border rounded"></canvas>

  <label class="text-sm mt-3">
    Número de colores (demo): <span class="font-mono palette-count-display">5</span>
  </label>
  <input type="range" min="3" max="10" step="1" value="5" class="palette-count w-full max-w-xs" />

  <div class="palette-colors grid grid-cols-2 sm:grid-cols-3 gap-3 w-full mt-4"></div>

  <p class="text-xs text-slate-500 text-center mt-3 max-w-sm">
    Esta demo extrae hasta <strong>10 colores dominantes únicos</strong>.
    En proyectos reales puedo implementar una versión avanzada que saque <strong>todas las paletas completas</strong>,
    exportables en varios formatos para diseño profesional.
  </p>
</div>

<script is:inline>
(() => {
  const root = document.currentScript.closest("div");
  const input = root.querySelector(".palette-input");
  const uploadBtn = root.querySelector(".palette-upload");
  const canvas = root.querySelector(".palette-canvas");
  const colorsBox = root.querySelector(".palette-colors");
  const range = root.querySelector(".palette-count");
  const rangeDisplay = root.querySelector(".palette-count-display");
  const ctx = canvas.getContext("2d");
  let img;

  uploadBtn.addEventListener("click", () => input.click());

  input.addEventListener("change", (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      img = new Image();
      img.onload = () => {
        // más detalle para logos
        canvas.width = 300;
        canvas.height = (img.height / img.width) * 300;
        ctx.imageSmoothingEnabled = false; // no mezclar bordes
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        canvas.classList.remove("hidden");
        extractColors();
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  });

  range.addEventListener("input", () => {
    rangeDisplay.textContent = range.value;
    if (img) extractColors();
  });

  function extractColors() {
    const { width, height } = canvas;
    const data = ctx.getImageData(0, 0, width, height).data;
    const samples = [];
    // muestreo mucho más denso
    for (let i = 0; i < data.length; i += 8) {
      samples.push([data[i], data[i + 1], data[i + 2]]);
    }

    const k = parseInt(range.value, 10);
    const centroids = samples.slice(0, k);
    for (let iter = 0; iter < 10; iter++) {
      const groups = Array.from({ length: k }, () => []);
      samples.forEach((p) => {
        let best = 0;
        let bestDist = Infinity;
        centroids.forEach((c, idx) => {
          const d = (p[0]-c[0])**2 + (p[1]-c[1])**2 + (p[2]-c[2])**2;
          if (d < bestDist) { bestDist = d; best = idx; }
        });
        groups[best].push(p);
      });
      groups.forEach((g, idx) => {
        if (g.length > 0) {
          centroids[idx] = [
            Math.round(g.reduce((s,p)=>s+p[0],0)/g.length),
            Math.round(g.reduce((s,p)=>s+p[1],0)/g.length),
            Math.round(g.reduce((s,p)=>s+p[2],0)/g.length),
          ];
        }
      });
    }

    // quitar duplicados y ordenar por brillo
    const uniqueHexes = Array.from(new Set(
      centroids.map((c) =>
        `#${c.map(x => x.toString(16).padStart(2,"0")).join("")}`
      )
    ));

    colorsBox.innerHTML = "";
    uniqueHexes.forEach((hex) => {
      const div = document.createElement("div");
      div.className = "rounded-lg shadow p-3 flex flex-col items-center justify-center text-sm cursor-pointer hover:scale-105 transition";
      div.style.backgroundColor = hex;
      div.innerHTML = `<span class="bg-white/80 rounded px-2 py-1 font-mono">${hex}</span>`;
      div.addEventListener("click", () => {
        navigator.clipboard.writeText(hex);
        div.querySelector("span").textContent = "Copiado!";
        setTimeout(()=>div.querySelector("span").textContent = hex, 1200);
      });
      colorsBox.appendChild(div);
    });
  }
})();
</script>
