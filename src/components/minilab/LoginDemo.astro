---
---
<div class="flex flex-col items-center justify-center w-full h-full p-6">
  <form
    id="login-form"
    class="w-full max-w-sm bg-[#0d0d0d] text-[#d3d3d3] p-6 rounded-xl shadow-lg space-y-4 relative overflow-hidden"
  >
    <h2 class="text-2xl font-bold text-center text-[#f7931e]">Demo de Login</h2>
    <p class="text-center text-sm text-gray-400">
      Ejemplo de formulario moderno con validación en vivo.
    </p>

    <!-- Email -->
    <div class="relative">
      <label for="login-email" class="block text-sm mb-1">Correo electrónico</label>
      <input
        type="email"
        id="login-email"
        placeholder="correo@ejemplo.com"
        class="w-full rounded-lg border border-gray-600 bg-black px-3 py-2 text-sm text-white placeholder-gray-500 focus:border-[#f7931e] focus:ring-2 focus:ring-[#f7931e] outline-none transition"
      />
    </div>

    <!-- Password -->
    <div class="relative">
      <label for="login-password" class="block text-sm mb-1">Contraseña</label>
      <input
        type="password"
        id="login-password"
        placeholder="********"
        class="w-full rounded-lg border border-gray-600 bg-black px-3 py-2 text-sm text-white placeholder-gray-500 focus:border-[#f7931e] focus:ring-2 focus:ring-[#f7931e] outline-none transition"
      />
    </div>

    <!-- Botón -->
    <button
      type="submit"
      class="w-full bg-[#f7931e] text-black py-2 text-sm font-bold rounded-lg transition-transform hover:scale-[1.02] active:scale-95"
    >
      Iniciar sesión
    </button>

    <div id="login-message" class="text-center text-sm mt-3 h-6"></div>
  </form>
</div>

<style is:global>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-6px); }
    40%, 80% { transform: translateX(6px); }
  }
  .shake {
    animation: shake 0.4s;
  }
  .success-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 15, 15, 0.9);
    display: grid;
    place-items: center; /* centra contenido */
    color: #f7931e;
    font-weight: bold;
    font-size: 1rem;
    animation: fadeIn 0.5s ease forwards;
    text-align: center; /* centra varias líneas */
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>

<script is:inline>
(() => {
  const form = document.getElementById("login-form");
  const email = document.getElementById("login-email");
  const password = document.getElementById("login-password");
  const msg = document.getElementById("login-message");

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const valueEmail = email.value.trim();
    const valuePass = password.value.trim();

    // Validaciones
    if (!/^[^@]+@[^@]+\.[^@]+$/.test(valueEmail)) {
      showError("❌ Correo inválido");
      return;
    }
    if (valuePass.length < 6) {
      showError("❌ Contraseña demasiado corta");
      return;
    }

    showSuccess();
  });

  function showError(text) {
    msg.textContent = text;
    msg.className = "text-center text-sm mt-2 text-red-500 shake";
  }

  function showSuccess() {
    msg.textContent = "";
    const overlay = document.createElement("div");
    overlay.className = "success-overlay";
    overlay.innerHTML = `
      <div class="flex flex-col items-center gap-3 text-center">
        <div class="w-6 h-6 border-4 border-[#f7931e] border-t-transparent rounded-full animate-spin"></div>
        <span>Inicio de sesión correcto. Cargando…</span>
      </div>
    `;
    form.appendChild(overlay);

    setTimeout(() => {
      overlay.innerHTML = `
        <div class="flex flex-col items-center text-center">
          <span>Bienvenido</span>
        </div>
      `;
    }, 2000);
  }
})();
</script>
