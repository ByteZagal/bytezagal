---
---
<div class="flex flex-col items-center justify-center w-full h-full gap-3">
  <input type="file" accept="image/*" class="hidden pixel-input" />
  <button class="cta white text-sm px-3 py-1.5 pixel-upload">Subir archivo</button>

  <canvas class="w-full max-h-60 border rounded pixel-canvas hidden"></canvas>

  <label class="text-sm">Tamaño de píxel</label>
  <input type="range" min="2" max="20" step="1" value="8" class="w-full pixel-size hidden" />

  <button class="cta black text-sm px-3 py-1.5 pixel-download hidden">
    Descargar pixelada
  </button>
</div>

<script is:inline>
(() => {
  const root = document.currentScript.closest("div");
  const input = root.querySelector(".pixel-input");
  const uploadBtn = root.querySelector(".pixel-upload");
  const sizeRange = root.querySelector(".pixel-size");
  const dl = root.querySelector(".pixel-download");
  const canvas = root.querySelector(".pixel-canvas");
  const ctx = canvas.getContext("2d");
  let img;

  uploadBtn.addEventListener("click", () => input.click());

  input.addEventListener("change", (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      img = new Image();
      img.onload = () => {
        canvas.width = img.width;
        canvas.height = img.height;
        ctx.drawImage(img, 0, 0); // primero pintar original
        pixelate(); // después aplicar pixelado
        canvas.classList.remove("hidden");
        sizeRange.classList.remove("hidden");
        dl.classList.remove("hidden");
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  });

  sizeRange.addEventListener("input", () => {
    if (img) pixelate();
  });

  function pixelate() {
    const pixelSize = parseInt(sizeRange.value, 10);

    // primero pintamos la imagen original
    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

    const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    const data = imgData.data;

    // recorrer bloques
    for (let y = 0; y < canvas.height; y += pixelSize) {
      for (let x = 0; x < canvas.width; x += pixelSize) {
        let r = 0, g = 0, b = 0, count = 0;
        for (let yy = 0; yy < pixelSize; yy++) {
          for (let xx = 0; xx < pixelSize; xx++) {
            const px = ( (y + yy) * canvas.width + (x + xx) ) * 4;
            if (px < data.length) {
              r += data[px];
              g += data[px + 1];
              b += data[px + 2];
              count++;
            }
          }
        }
        r = Math.floor(r / count);
        g = Math.floor(g / count);
        b = Math.floor(b / count);

        ctx.fillStyle = `rgb(${r},${g},${b})`;
        ctx.fillRect(x, y, pixelSize, pixelSize);
      }
    }
  }

  dl.addEventListener("click", () => {
    canvas.toBlob((blob) => {
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "pixelado.png";
      a.click();
    });
  });
})();
</script>
