---
import { MessageCircle, Mail, Linkedin, Instagram, Github, Music } from "lucide-astro";

const WHATSAPP = "https://wa.me/34650850163?text=Hola%20Pedro,%20quiero%20hablar%20sobre%20mi%20web.";
const EMAIL = "bytezagal.contacto@gmail.com";
---
<section id="contacto" class="relative py-24">
  <div class="mx-auto max-w-4xl px-4">
    <div class="rounded-2xl bg-white p-8 shadow-lg ring-1 ring-slate-200" data-reveal>
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 text-center">Contacto</h2>
      <p class="mt-2 text-center text-slate-600">¿Tienes un proyecto en mente? Escríbeme y lo hablamos sin compromiso.</p>

      <div class="mt-7 grid gap-3 sm:grid-cols-2">
        <a href={WHATSAPP} target="_blank" rel="noopener noreferrer"
           class="cta-main inline-flex items-center justify-center gap-2 rounded-lg px-5 py-3 bg-green-700 text-white font-semibold shadow hover:bg-green-800 transition focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-green-700"
           aria-label="Abrir conversación por WhatsApp" data-reveal data-reveal-delay="120">
          <MessageCircle class="h-5 w-5" /> WhatsApp
        </a>
        <a href="/contratame"
           class="cta-attn inline-flex items-center justify-center gap-2 rounded-lg px-5 py-3 bg-black text-white font-semibold shadow hover:opacity-90 transition focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-black"
           data-reveal data-reveal-delay="180">
          💶 Ver precios y paquetes
        </a>
      </div>

      <div class="mt-4 text-center text-sm" data-reveal data-reveal-delay="240">
        <a class="underline underline-offset-2 mr-3" href="/servicios/digitalizacion">Digitalización</a>
        <a class="underline underline-offset-2 mr-3" href="/servicios/ecommerce">Ecommerce</a>
        <a class="underline underline-offset-2" href="/servicios/arreglos">Arreglos</a>
      </div>

      <div class="mt-6 flex justify-center" data-reveal data-reveal-delay="300">
        <a href={`mailto:${EMAIL}`} class="inline-flex items-center justify-center gap-2 rounded-lg px-5 py-3 border border-slate-300 font-semibold hover:bg-slate-50 transition focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-slate-400">
          <Mail class="h-5 w-5" /> {EMAIL}
        </a>
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-center gap-3" data-reveal data-reveal-delay="360">
        <a href="https://www.linkedin.com/in/pedro-aguilar-lopez-569533233/" target="_blank" rel="noopener noreferrer" class="chip inline-flex items-center gap-2 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-slate-400" aria-label="LinkedIn">
          <Linkedin class="h-4 w-4" /> LinkedIn
        </a>
        <a href="https://instagram.com/bytezagal" target="_blank" rel="noopener noreferrer" class="chip inline-flex items-center gap-2 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-slate-400" aria-label="Instagram">
          <Instagram class="h-4 w-4" /> Instagram
        </a>
        <a href="https://www.tiktok.com/@bytezagal" target="_blank" rel="noopener noreferrer" class="chip inline-flex items-center gap-2 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-slate-400" aria-label="TikTok">
          <Music class="h-4 w-4" /> TikTok
        </a>
        <a href="https://github.com/ByteZagal" target="_blank" rel="noopener noreferrer" class="chip inline-flex items-center gap-2 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-slate-400" aria-label="GitHub">
          <Github class="h-4 w-4" /> GitHub
        </a>
      </div>

      <p class="mt-6 text-center text-xs text-slate-500" data-reveal data-reveal-delay="420">
        Tus datos no se almacenan. El mensaje se envía directamente a mi correo/WhatsApp y será tratado conforme al <strong>RGPD</strong>.
      </p>
    </div>
  </div>

  <style>
    [data-reveal]{opacity:0;transform:translateY(8px)}
    .reveal-in{opacity:1;transform:none;transition:opacity .5s ease,transform .5s ease}
    @keyframes pulse-cta{0%,98%,100%{transform:none}99%{transform:scale(1.015)}}
    .cta-main{animation:pulse-cta 8s infinite}
    .cta-attn{animation:pulse-cta 10s infinite}
    @media (prefers-reduced-motion: reduce){
      .cta-main,.cta-attn{animation:none !important}
      .reveal-in{transition:none !important}
    }
  </style>

  <script is:inline>
    (function(){
      const els = Array.from(document.querySelectorAll('#contacto [data-reveal]'));
      if (!('IntersectionObserver' in window) || els.length===0){ els.forEach(el=>el.classList.add('reveal-in')); return; }
      const io = new IntersectionObserver((entries)=>{
        entries.forEach((e)=>{
          if(e.isIntersecting){
            const d = parseInt(e.target.getAttribute('data-reveal-delay')||'0',10);
            setTimeout(()=>e.target.classList.add('reveal-in'), d);
            io.unobserve(e.target);
          }
        });
      },{threshold:0.12});
      els.forEach(el=>io.observe(el));
    })();
  </script>
</section>
