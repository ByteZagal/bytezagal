---
interface Faq {
  question: string;
  answer: string;
}

interface Props {
  faqs: Faq[];
}

const { faqs } = Astro.props as Props;
---
<section aria-labelledby="faq-title" class="mx-auto mt-16 max-w-5xl rounded-2xl">
  <h2 id="faq-title" class="text-2xl font-extrabold text-slate-900">Preguntas frecuentes</h2>
  <div class="mt-6 grid gap-4">
    {faqs.map((f) => (
      <details class="rounded-lg border border-slate-200 p-4">
        <summary class="font-semibold cursor-pointer">{f.question}</summary>
        <p class="mt-2 text-slate-600">{f.answer}</p>
      </details>
    ))}
  </div>
</section>
